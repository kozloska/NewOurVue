# .env.example
# === API Configuration ===
# Скопируйте этот файл в .env и заполните значения

# Локальная разработка (по умолчанию)
VUE_APP_API_BASE_URL=http://localhost:8000

# Для Vite (если используешь):
# VITE_API_BASE_URL=http://localhost:8000

# === Пример для продакшена (не заполнять, только для справки) ===
# VUE_APP_API_BASE_URL=http://172.28.20.54
# или
# VUE_APP_API_BASE_URL=https://api.yourdomain.com